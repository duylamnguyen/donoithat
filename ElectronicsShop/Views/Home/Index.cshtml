@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}
@section Scripts {
    <script>
        const clockExpire = document.querySelector("#hot-deal");

        if (clockExpire) {
            // Ngày kết thúc
            var countDownDate = new Date("May 30, 2026 12:00:00").getTime();

            // Cập nhật đồng hồ mỗi 1 giây
            var x = setInterval(function () {
                var now = new Date().getTime();
                var distance = countDownDate - now;

                var days = Math.floor(distance / (1000 * 60 * 60 * 24));
                var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);


                document.getElementById("days").innerHTML = days < 10 ? "0" + days : days;
                document.getElementById("hours").innerHTML = hours < 10 ? "0" + hours : hours;
                document.getElementById("minutes").innerHTML = minutes < 10 ? "0" + minutes : minutes;
                document.getElementById("seconds").innerHTML = seconds < 10 ? "0" + seconds : seconds;


                if (distance < 0) {
                    clearInterval(x);
                    document.querySelector(".hot-deal-countdown").innerHTML = "<li><h3>HẾT HẠN</h3></li>";
                }
            }, 1000);
        }
    </script>

}
@section Styles {
    <style>
        .product .product-body .product-category {
            text-transform: uppercase;
            font-size: 12px;
            color: #8D99AE;
            height: 15px;
            margin-bottom: 5px;
            display: block;
        }

        .product .product-body .product-name {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            height: 25px;
            line-height: 25px;
            margin: 5px 0;
        }

        .product .product-body .product-price {
            color: #aa9381;
            font-size: 18px;
            font-weight: 700;
            margin: 10px 0;
            height: 45px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

            .product .product-body .product-price .product-old {
                font-size: 12px;
                font-weight: 400;
                color: #8D99AE;
                text-decoration: line-through;
                margin-left: 0;
            }

        .product .product-rating {
            height: 20px;
            margin-bottom: 10px;
        }

        .shop {
            position: relative;
            overflow: hidden;
            background-color: #f5f5f5;
            height: 240px;
            border-radius: 10px;
            border: 1px solid #E4E7ED;
            transition: 0.3s all;
        }

        .shop-body h3 {
            color: #2B2D42;
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            line-height: 1.2;
        }

            .shop-body h3 br + span {
                color: #8D99AE;
                font-size: 14px;
                font-weight: 400;
            }

        .shop-body .cta-btn {
            color: #aa9381;
            text-transform: uppercase;
            font-weight: 700;
            font-size: 12px;
            display: inline-block;
            margin-top: 5px;
        }

            .shop-body .cta-btn i {
                padding-left: 5px;
            }

        .shop-body .cta-btn {
            color: #aa9381;
            text-transform: uppercase;
            font-weight: 700;
            font-size: 12px;
            display: inline-block;
            margin-top: 5px;
        }

            .shop-body .cta-btn i {
                padding-left: 5px;
            }

        .shop .shop-img {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            z-index: 0;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 15px;
        }

            .shop .shop-img img {
                opacity: 1 !important;
                visibility: visible !important;
                display: block !important;
                max-height: 180px;
                width: auto;
                object-fit: contain;
                -webkit-transform: skewX(-15deg) scale(1) !important;
                transform: skewX(-15deg) scale(1) !important;
                mix-blend-mode: multiply;
                transition: 0.3s all;
            }

        .shop:hover .shop-img img {
            -webkit-transform: skewX(-15deg) scale(1.1) !important;
            transform: skewX(-15deg) scale(1.1) !important;
        }

        /* Fixed image frame so all product cards align visually */
        .product .product-img {
            position: relative;
        }

        .product .product-image-frame {
            width: 100%;
            height: 220px; /* adjust height as you prefer */
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #fff;
        }

            .product .product-image-frame img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain; /* keep aspect ratio, center the image */
                display: block;
            }

        /* small visual tweak for stock line */
        .product .product-stock {
            color: #777;
            font-size: 13px;
            margin-top: 6px;
        }
    </style>
}

<!-- SECTION -->
<div class="section">
    <!-- container -->
    <div class="container">
        <!-- row -->
        <div class="row">
            @foreach (var category in ViewBag.Categories)
            {
                <div class="col-md-3 col-xs-6">
                    <div class="shop" style="margin-bottom: 30px;">
                        <div class="shop-img">
                            @{
                                var catName = category.category_name.ToLower();
                                var imgName = "shop01.png"; // Mặc định Laptop

                                if (catName.Contains("Giường") || catName.Contains("giường"))
                                {
                                    imgName = "Giuong.jpg"; //
                                }
                                else if (catName.Contains("Tủ quần áo") || catName.Contains("tủ quần áo"))
                                {
                                    imgName = "tu-quan-ao.jpg"; //
                                }
                                else if (catName.Contains("sofa") || catName.Contains("sofa"))
                                {
                                    imgName = "sofa.jpg";
                                }
                                else if (catName.Contains("Bàn ghế ăn") || catName.Contains("bàn ghế ăn"))
                                {
                                    imgName = "Ban-an.jpg";
                                }
                                var finalPath = Url.Content("~/Images/" + imgName);
                            }
                            <img src="@finalPath" alt="@category.category_name">
                        </div>
                        <div class="shop-body">
                            <h3>@category.category_name<br>Bộ sưu tập</h3>
                            <a href="@Url.Action("ProductsByCategory", "Product", new { categoryId = category.category_id })" class="cta-btn">
                                Mua sắm ngay <i class="fa fa-arrow-circle-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <!-- /container -->
</div>
<!-- /SECTION -->
