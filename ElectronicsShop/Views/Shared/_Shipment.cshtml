@model ElectronicsShop.Models.Shipment

<div class="card shadow-sm mb-3">
    <div class="card-body">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h6 class="mb-1 fw-bold">
                    @Model.recipient_first_name @Model.recipient_last_name
                </h6>
                <div class="text-muted">
                    (+84) @Model.recipient_phone
                </div>
            </div>
        </div>

        <!-- Address -->
        <div class="mb-3">
            <div>@Model.shipment_address</div>
            <div class="text-muted">
                @Model.shipment_city,
                @Model.shipment_country
            </div>
        </div>

        <!-- Footer -->
        <div class="d-flex justify-content-between align-items-center">
            <span class="badge bg-success">
                Mặc định
            </span>

            <button class="btn btn-secondary btn-sm" disabled>
                Thiết lập mặc định
            </button>
        </div>

    </div>
</div>
