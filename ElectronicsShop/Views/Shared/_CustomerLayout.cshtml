<head>
    <style>
        /* ===== GLOBAL THEME (Interior Style) ===== */
        body {
            background: #F8F5F2;
            color: #333;
        }

        a {
            color: #8B5E3C;
            transition: 0.2s;
        }

            a:hover {
                color: #A67C52;
            }

        /* ===== NAVIGATION ===== */
        .main-nav li a {
            position: relative;
            padding-bottom: 5px;
        }

        .main-nav li.active a {
            color: #8B5E3C !important;
            background-color: transparent !important;
            font-weight: 600;
        }

            .main-nav li.active a::after {
                content: "";
                display: block;
                width: 100%;
                height: 2px;
                background-color: #D6A77A;
                position: absolute;
                bottom: 0;
                left: 0;
            }

        /* ===== CHAT WIDGET ===== */
        .chat-bubble {
            position: fixed;
            right: 22px;
            bottom: 22px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, #8B5E3C, #A67C52);
            color: #fff;
            border: none;
            box-shadow: 0 6px 18px rgba(0,0,0,0.18);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1200;
            font-size: 20px;
        }

        /* Popup */
        .chat-popup {
            position: fixed;
            right: 22px;
            bottom: 90px;
            width: 360px;
            max-width: calc(100% - 44px);
            height: 460px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            z-index: 1199;
            display: none;
            flex-direction: column;
            overflow: hidden;
        }

            .chat-popup.open {
                display: flex;
            }

        /* Header */
        .chat-header {
            padding: 12px 14px;
            background: linear-gradient(135deg, #8B5E3C, #A67C52);
            color: #fff;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .chat-header .close-btn {
                background: transparent;
                border: none;
                color: #fff;
                font-size: 18px;
                cursor: pointer;
            }

        /* Content */
        .chat-content {
            padding: 12px;
            background: #F8F5F2;
            overflow-y: auto;
            flex: 1 1 auto;
        }

        /* Messages */
        .chat-message {
            margin-bottom: 10px;
            display: block;
        }

            .chat-message .meta {
                font-size: 0.85rem;
                color: #777;
                margin-bottom: 4px;
            }

            .chat-message .text {
                background: #fff;
                padding: 8px 10px;
                border-radius: 10px;
                display: inline-block;
                max-width: 90%;
                border: 1px solid #eee;
            }

            .chat-message.user .text {
                background: #D6A77A;
                color: #fff;
            }

        /* Input */
        .chat-input {
            padding: 10px;
            display: flex;
            gap: 8px;
            border-top: 1px solid #eee;
            align-items: center;
        }

            .chat-input input[type="text"] {
                flex: 1;
                padding: 8px 10px;
                border: 1px solid #e0d6cf;
                border-radius: 6px;
                background: #fff;
            }

            .chat-input button {
                padding: 8px 12px;
                border-radius: 6px;
                background: #8B5E3C;
                color: #fff;
                border: none;
                cursor: pointer;
            }

                .chat-input button:hover {
                    background: #6f4a2f;
                }

        /* Loading text */
        .chat-loading {
            font-style: italic;
            color: #999;
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .chat-popup {
                width: 320px;
                height: 420px;
                right: 12px;
                bottom: 78px;
            }

            .chat-bubble {
                right: 12px;
                bottom: 12px;
            }
        }
    </style>
