            <span>Trợ lý AI</span>
            <button class="close-btn" id="chatClose" aria-label="Đóng">&times;</button>
        </div>
        <div id="chatContent" class="chat-content" role="log" aria-live="polite"></div>
        <div class="chat-input">
            <input id="chatMessage" type="text" placeholder="Gõ câu hỏi..." aria-label="Nhập câu hỏi" />
            <button id="chatSend" type="button">Gửi</button>
