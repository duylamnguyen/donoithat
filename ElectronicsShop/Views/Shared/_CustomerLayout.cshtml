    <div style="display:none">
        @Html.AntiForgeryToken()
    </div>
    <script>
        window.wishlistAddUrl = '@Url.Action("Add", "Wishlist")';
        window.wishlistLoginUrl = '@Url.Action("Login", "Account")';
        window.cartAddUrl = '@Url.Action("Add", "Cart")';
        window.cartRemoveUrl = '@Url.Action("Remove", "Cart")';
        window.cartLoginUrl = '@Url.Action("Login", "Account")';
    </script>

    <script>
        (function () {
            // Elements
            var toggle = document.getElementById('chatToggle');
            var popup = document.getElementById('chatPopup');
            var closeBtn = document.getElementById('chatClose');
            var sendBtn = document.getElementById('chatSend');
            var input = document.getElementById('chatMessage');
            var content = document.getElementById('chatContent');

            var chatUrl = '@Url.Action("Send", "Chat")';
            // get anti-forgery token value if present
            var afElem = document.querySelector('input[name="__RequestVerificationToken"]');
            var afToken = afElem ? afElem.value : null;

            function openPopup() {
                popup.classList.add('open');
                popup.setAttribute('aria-hidden', 'false');
                input.focus();
            }
            function closePopup() {
                popup.classList.remove('open');
                popup.setAttribute('aria-hidden', 'true');
                toggle.focus();
            }

            function appendMessage(who, text, cssClass) {
                var wrap = document.createElement('div');
                wrap.className = 'chat-message ' + (cssClass || '');
                var meta = document.createElement('div');
                meta.className = 'meta';
                meta.textContent = who;
                var txt = document.createElement('div');
                txt.className = 'text';
                txt.textContent = text;
                wrap.appendChild(meta);
                wrap.appendChild(txt);
                content.appendChild(wrap);
                content.scrollTop = content.scrollHeight;
            }

            function appendLoading() {
                var l = document.createElement('div');
                l.className = 'chat-message loading';
                l.innerHTML = '<div class="chat-loading">Đang xử lý...</div>';
                content.appendChild(l);
                content.scrollTop = content.scrollHeight;
                return l;
            }

            async function sendMessage() {
                var msg = input.value.trim();
                if (!msg) return;
                appendMessage('Bạn', msg, 'user');
                input.value = '';
                var loading = appendLoading();

                try {
                    var form = new FormData();
                    form.append('message', msg);
                    if (afToken) form.append('__RequestVerificationToken', afToken);

                    var res = await fetch(chatUrl, {
                        method: 'POST',
                        body: form,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    var j = await res.json();
                    content.removeChild(loading);

                    if (j.ok) {
                        appendMessage('Trợ lý', j.reply, 'assistant');
                    } else {
                        appendMessage('Hệ thống', j.error || 'Lỗi khi gọi trợ lý', 'error');
                    }
                } catch (e) {
                    if (content.contains(loading)) content.removeChild(loading);
                    appendMessage('Hệ thống', e.message || 'Lỗi kết nối', 'error');
                }
            }

            // events
            toggle.addEventListener('click', function () {
                if (popup.classList.contains('open')) closePopup(); else openPopup();
            });
            closeBtn.addEventListener('click', closePopup);
            sendBtn.addEventListener('click', sendMessage);
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // close when clicked outside (optional)
            document.addEventListener('click', function (e) {
                if (!popup.contains(e.target) && !toggle.contains(e.target) && popup.classList.contains('open')) {
                    closePopup();
                }
            });
        })();
    </script>

    @RenderSection("Scripts", required: false)

</body>
