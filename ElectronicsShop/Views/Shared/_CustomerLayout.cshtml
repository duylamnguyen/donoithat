@section Scripts {
    <script>
        try {
            window.addEventListener("load", function () {
                var currentPath = window.location.pathname.toLowerCase().replace(/\/$/, "");

                var navLinks = document.querySelectorAll('.main-nav li a');
                var found = false;

                navLinks.forEach(function (link) {
                    var linkPath = new URL(link.href).pathname.toLowerCase().replace(/\/$/, "");

                    link.parentElement.classList.remove('active');

                    if (currentPath === linkPath || (currentPath !== "" && currentPath.includes(linkPath) && linkPath.length > 5)) {
                        link.parentElement.classList.add('active');
                        found = true;
                    }
                });

                if (!found || currentPath.endsWith("hocrest_ful") || currentPath.includes("home/index")) {
                    var firstLi = document.querySelector('.main-nav li:first-child');
                    if (firstLi) {
                        navLinks.forEach(l => l.parentElement.classList.remove('active'));
                        firstLi.classList.add('active');
                    }
                }
            });
        } catch (e) {
            console.error("Lỗi script focus menu: ", e);
        }
    </script>
}
<!DOCTYPE html>
