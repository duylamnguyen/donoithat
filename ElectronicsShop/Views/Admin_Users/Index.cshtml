@model IEnumerable<ElectronicsShop.Models.User>

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Đồng bộ với style Admin_Products / Admin_Categories */
    .users-card .card-header h5 {
        font-weight: 700;
        color: #0d6efd;
    }

    .users-table thead th {
        font-size: 15px;
        font-weight: 700;
        color: #0d6efd;
        background-color: transparent;
        border-bottom: 2px solid rgba(13,110,253,0.08);
        vertical-align: middle;
    }

    .users-table tbody td {
        vertical-align: middle;
    }

    .user-name {
        font-weight: 600;
        color: #0b5ed7;
    }

    /* Các nút thao tác có kích thước bằng nhau */
    .actions .btn {
        min-width: 92px;
        margin-right: 6px;
        padding: .325rem .5rem;
        font-size: .88rem;
        text-align: center;
    }

    /* Pagination */
    .paging {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: flex-end;
        margin-bottom: 12px;
    }

        .paging .page-btn {
            padding: 6px 10px;
            border-radius: 4px;
            border: 1px solid #e3e6ea;
            background: #fff;
            cursor: pointer;
        }

            .paging .page-btn.active {
                background: #0d6efd;
                color: #fff;
                border-color: #0d6efd;
            }

        .paging .page-size {
            width: 80px;
        }

    /* sortable */
    .users-table thead th.sortable {
        cursor: pointer;
        user-select: none;
    }

    .sort-indicator {
        margin-left: 6px;
        font-size: 0.85em;
        color: #6c757d;
    }

    /* Responsive nhỏ */
    @@media (max-width: 576px) {
        .actions .btn {
            min-width: 72px;
            font-size: 0.82rem;
            padding: .25rem .4rem;
        }

        .users-table thead th {
            font-size: 13px;
        }
    }
</style>

<div class="card mb-4 users-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách người dùng</h5>
        <div>
            @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-sm btn-success" })
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0 users-table">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="first_name">Họ <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="last_name">Tên <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="email">Email <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="phone">Phone <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="role">Vai trò <span class="sort-indicator"></span></th>
                        <th style="width:240px">Hành động</th>
                    </tr>
                </thead>
                <tbody id="usersTbody">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Không có người dùng nào</td>
                        </tr>
                    }
                    else
                    {
                        var rowIndex = 0;
                        foreach (var item in Model)
                        {
                            rowIndex++;
                            <tr class="data-row" data-index="@rowIndex">
                                <td>
                                    @Html.DisplayFor(modelItem => item.first_name)
                                </td>
                                <td>
                                    <div class="user-name">@Html.DisplayFor(modelItem => item.last_name)</div>
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.email)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.phone)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.role)
                                </td>
                                <td class="actions">
                                    <div class="d-flex flex-column gap-2">

                                        @Html.ActionLink("Chi tiết", "Details", new { id = item.user_id }, new { @class = "btn btn-sm btn-outline-primary" })
                                        @Html.ActionLink("Sửa", "Edit", new { id = item.user_id }, new { @class = "btn btn-sm btn-outline-secondary" })
                                        @Html.ActionLink("Xóa", "Delete", new { id = item.user_id }, new { @class = "btn btn-sm btn-outline-danger", onclick = "return confirm('Bạn có chắc muốn xóa người dùng này?');" })
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination controls -->
        <div class="paging" aria-label="Pagination controls">
            <div>
                <label for="userPageSize">Số hàng / trang</label>
                <select id="userPageSize" class="form-select page-size">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                </select>
            </div>

            <div style="margin-left:auto; display:flex; gap:6px; align-items:center;">
                <button id="userFirstPage" class="page-btn" type="button">&laquo; Đầu</button>
                <button id="userPrevPage" class="page-btn" type="button">&lsaquo; Trước</button>
                <div id="userPageNumbers" style="display:flex; gap:6px;"></div>
                <button id="userNextPage" class="page-btn" type="button">Tiếp &rsaquo;</button>
                <button id="userLastPage" class="page-btn" type="button">Cuối &raquo;</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Client-side sorting + pagination for Users
    document.addEventListener('DOMContentLoaded', function () {
        const tbody = document.getElementById('usersTbody');
        let items = Array.from(tbody.querySelectorAll('.data-row')).map(row => {
            const tds = row.querySelectorAll('td');
            const getText = idx => (tds[idx] ? tds[idx].innerText.trim() : '').toLowerCase();
            return {
                row: row,
                first_name: getText(0),
                last_name: getText(1),
                email: getText(2),
                phone: getText(3),
                role: getText(4)
            };
        });

        let rowsElems = items.map(i => i.row);
        const headers = Array.from(document.querySelectorAll('.users-table thead th.sortable'));
        let currentSort = { key: null, dir: null };

        function setSortIndicator(header, dir) {
            headers.forEach(h => {
                const ind = h.querySelector('.sort-indicator');
                if (h === header) ind.textContent = dir === 'asc' ? '▲' : dir === 'desc' ? '▼' : '';
                else ind.textContent = '';
            });
        }

        function compareValues(a, b, key, dir) {
            const va = a[key] || '', vb = b[key] || '';
            if (va < vb) return dir === 'asc' ? -1 : 1;
            if (va > vb) return dir === 'asc' ? 1 : -1;
            return 0;
        }

        headers.forEach(h => {
            h.addEventListener('click', function () {
                const key = this.dataset.sort;
                let dir = 'asc';
                if (currentSort.key === key) dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                currentSort = { key, dir };

                items.sort((a, b) => compareValues(a, b, key, dir));
                items.forEach(it => tbody.appendChild(it.row));
                rowsElems = items.map(i => i.row);

                setSortIndicator(this, dir);

                currentPage = 1;
                showPage(currentPage);
            });
        });

        // pagination (uses rowsElems)
        const pageSizeSelect = document.getElementById('userPageSize');
        const pageNumbersContainer = document.getElementById('userPageNumbers');
        const firstBtn = document.getElementById('userFirstPage');
        const prevBtn = document.getElementById('userPrevPage');
        const nextBtn = document.getElementById('userNextPage');
        const lastBtn = document.getElementById('userLastPage');

        let pageSize = parseInt(pageSizeSelect.value, 10) || 10;
        let currentPage = 1;

        function calculateTotalPages() {
            return pageSize > 0 ? Math.max(1, Math.ceil(rowsElems.length / pageSize)) : 1;
        }

        function renderPageNumbers() {
            pageNumbersContainer.innerHTML = '';
            const totalPages = calculateTotalPages();
            const maxButtons = 7;
            let start = Math.max(1, currentPage - Math.floor(maxButtons / 2));
            let end = Math.min(totalPages, start + maxButtons - 1);
            if (end - start + 1 < maxButtons) { start = Math.max(1, end - maxButtons + 1); }
            for (let i = start; i <= end; i++) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                btn.textContent = i;
                btn.dataset.page = i;
                btn.addEventListener('click', function () {
                    currentPage = parseInt(this.dataset.page, 10);
                    showPage(currentPage);
                });
                pageNumbersContainer.appendChild(btn);
            }
        }

        function showPage(page) {
            const totalPages = calculateTotalPages();
            if (page < 1) page = 1;
            if (page > totalPages) page = totalPages;
            currentPage = page;
            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = startIndex + pageSize;
            rowsElems.forEach((r, idx) => {
                r.style.display = (idx >= startIndex && idx < endIndex) ? '' : 'none';
            });
            renderPageNumbers();
            prevBtn.disabled = currentPage === 1;
            firstBtn.disabled = currentPage === 1;
            nextBtn.disabled = currentPage === totalPages;
            lastBtn.disabled = currentPage === totalPages;
        }

        pageSizeSelect.addEventListener('change', function () {
            pageSize = parseInt(this.value, 10) || 10;
            currentPage = 1;
            showPage(currentPage);
        });
        firstBtn.addEventListener('click', function () { showPage(1); });
        prevBtn.addEventListener('click', function () { showPage(currentPage - 1); });
        nextBtn.addEventListener('click', function () { showPage(currentPage + 1); });
        lastBtn.addEventListener('click', function () { showPage(calculateTotalPages()); });

        // initial render
        showPage(1);
    });
</script>