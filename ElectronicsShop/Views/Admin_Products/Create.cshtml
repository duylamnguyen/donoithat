<div>
    @Html.ActionLink("Trở về danh sách", "Index")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
<style>
    .img-box { position:relative; display:inline-block; margin-right:10px; margin-bottom:10px; }
    .img-box img { width:200px; height:auto; }
    .img-box .remove-btn {
        position:absolute; top:5px; right:5px; background:#c00; color:white; border-radius:50%; width:26px; height:26px;
        text-align:center; line-height:24px; cursor:pointer; font-weight:bold;
    }
</style>
<script>
    var nextInputId = 0;
    function addFileInput() {
        var container = document.getElementById("fileInputs");
        var id = nextInputId++;
        var wrapper = document.createElement("div");
        wrapper.id = "fi_" + id;
        wrapper.style.marginBottom = "10px";

        var input = document.createElement("input");
        input.type = "file";
        input.name = "images";
        input.onchange = (function(localId) {
            return function (e) { previewFile(e, localId); };
        })(id);

        var previewBox = document.createElement("div");
        previewBox.id = "preview_" + id;
        previewBox.className = "img-box";

        var remove = document.createElement("span");
        remove.className = "remove-btn";
        remove.innerText = "x";
        remove.title = "Xóa";
        remove.onclick = (function(localId) {
            return function () { removeFileInput(localId); };
        })(id);

        wrapper.appendChild(input);
        wrapper.appendChild(previewBox);
        wrapper.appendChild(remove);
        container.appendChild(wrapper);
    }

    function removeFileInput(id) {
        var el = document.getElementById("fi_" + id);
        if (el) el.parentNode.removeChild(el);
    }

    function previewFile(event, id) {
        var files = event.target.files;
        var box = document.getElementById("preview_" + id);
        box.innerHTML = "";
        if (!files || files.length === 0) return;
        var img = document.createElement("img");
        img.src = URL.createObjectURL(files[0]);
        img.className = "img-thumbnail";
        box.appendChild(img);
    }
</script>