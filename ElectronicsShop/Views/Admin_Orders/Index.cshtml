@model IEnumerable<ElectronicsShop.Models.Order>

@{
    ViewBag.Title = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Đồng bộ với các trang admin khác */
    .orders-card .card-header h5 {
        font-weight: 700;
        color: #0d6efd;
    }

    .orders-table thead th {
        font-size: 15px;
        font-weight: 700;
        color: #0d6efd;
        background-color: transparent;
        border-bottom: 2px solid rgba(13,110,253,0.08);
        vertical-align: middle;
    }

    .orders-table tbody td {
        vertical-align: middle;
        word-break: break-word;
    }

    /* Ngăn không cho ngày xuống hàng */
    .orders-table td.date-cell {
        white-space: nowrap;
        word-break: normal; /* tránh break-word cho ô ngày */
    }

    /* Các nút thao tác có kích thước bằng nhau */
    .actions .btn {
        min-width: 120px; /* tất cả nút hành động có cùng kích thước tối thiểu */
        margin-right: 6px;
        padding: .325rem .5rem;
        font-size: .88rem;
        text-align: center;
    }

    /* Badge trạng thái */
    .badge-status {
        font-weight: 700;
        padding: .35rem .6rem;
        border-radius: .375rem;
        color: #fff;
        display: inline-block;
        font-size: .9rem;
    }

    .badge-pending {
        background: #f59e0b;
    }
    /* vàng */
    .badge-shipped {
        background: #0ea5b7;
    }
    /* xanh dương biển nhẹ */
    .badge-completed {
        background: #16a34a;
    }
    /* xanh lá */
    .badge-cancel {
        background: #ef4444;
    }
    /* đỏ */
    .badge-other {
        background: #6c757d;
    }
    /* xám */

    /* Ghi chú xuống dòng khi dài */
    .order-note {
        max-width: 360px;
        white-space: normal;
        word-break: break-word;
        color: #495057;
    }

    /* Pagination */
    .paging {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: flex-end;
        margin-bottom: 12px;
    }

        .paging .page-btn {
            padding: 6px 10px;
            border-radius: 4px;
            border: 1px solid #e3e6ea;
            background: #fff;
            cursor: pointer;
        }

            .paging .page-btn.active {
                background: #0d6efd;
                color: #fff;
                border-color: #0d6efd;
            }

        .paging .page-size {
            width: 80px;
        }

    /* sortable */
    .orders-table thead th.sortable {
        cursor: pointer;
        user-select: none;
    }

    .sort-indicator {
        margin-left: 6px;
        font-size: 0.85em;
        color: #6c757d;
    }

    /* Responsive nhỏ */
    @@media (max-width: 768px) {
        .actions .btn {
            min-width: 92px;
            font-size: .82rem;
            padding: .25rem .4rem;
        }

        .order-note {
            max-width: 200px;
        }
    }
</style>

<div class="card mb-4 orders-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách đơn hàng</h5>
        <div>
            @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-sm btn-success" })
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0 orders-table">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="shipment_address">Địa chỉ giao <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="customer">Khách hàng <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="order_date">Ngày <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="total_amount" style="min-width:120px">Tổng tiền <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="status">Trạng thái <span class="sort-indicator"></span></th>
                        <th class="sortable" data-sort="payment_method">Thanh toán <span class="sort-indicator"></span></th>
                        <th>Ghi chú</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="ordersTbody">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">Không có đơn hàng nào</td>
                        </tr>
                    }
                    else
                    {
                        var rowIndex = 0;
                        foreach (var item in Model)
                        {
                            rowIndex++;
                            <tr class="data-row" data-index="@rowIndex">
                                <td>
                                    @Html.DisplayFor(modelItem => item.Shipment.shipment_address)
                                </td>
                                <td>
                                    @{
                                        var customerName = item.User != null
                                            ? (item.User.first_name ?? "") + " " + (item.User.last_name ?? "")
                                            : "—";
                                    }
                                    @customerName
                                </td>
                                <td class="date-cell">
                                    @((item.order_date != null) ? item.order_date.Value.ToString("dd/MM/yyyy") : "—")
                                </td>
                                <td>
                                    @{
                                        var totalText = item.total_amount != null ? String.Format("{0:N0} ₫", item.total_amount) : "-";
                                    }
                                    @totalText
                                </td>
                                <td>
                                    @{
                                        /* Map trạng thái sang tiếng Việt dựa trên các giá trị trong Edit.cshtml */
                                        var raw = (item.status ?? "").ToString().Trim();
                                        var lower = raw.ToLowerInvariant();
                                        string label = raw;
                                        string badgeClass = "badge-other";

                                        if (lower == "processing" || lower.Contains("processing"))
                                        {
                                            label = "Đang chuẩn bị hàng";
                                            badgeClass = "badge-pending";
                                        }
                                        else if (lower.Contains("pendingpayment") || lower.Contains("pendingpayment"))
                                        {
                                            label = "Chờ thanh toán";
                                            badgeClass = "badge-cancel";
                                        }
                                        else if (lower == "shipping" || lower.Contains("shipping"))
                                        {
                                            label = "Đang vận chuyển";
                                            badgeClass = "badge-shipped";
                                        }
                                        else if (lower == "delivered" || lower.Contains("delivered"))
                                        {
                                            label = "Đã giao";
                                            badgeClass = "badge-completed";
                                        }
                                        else if (lower.Contains("cancel") || lower.Contains("hủy"))
                                        {
                                            label = "Đã hủy";
                                            badgeClass = "badge-cancel";
                                        }
                                    }
                                    <span class="badge-status @badgeClass">@label</span>
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.payment_method)
                                </td>
                                <td>
                                    <div class="order-note" title="@item.order_note">@item.order_note</div>
                                </td>
                                <td class="actions">
                                    @Html.ActionLink("Thay đổi trạng thái", "Edit", new { id = item.order_id }, new { @class = "btn btn-sm btn-outline-secondary w-75 m-1" })
                                    @Html.ActionLink("Chi tiết", "Details", new { id = item.order_id }, new { @class = "btn btn-sm btn-outline-primary w-75 m-1" })
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination controls -->
        <div class="paging" aria-label="Pagination controls">
            <div>
                <label for="orderPageSize">Số hàng / trang</label>
                <select id="orderPageSize" class="form-select page-size">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                </select>
            </div>

            <div style="margin-left:auto; display:flex; gap:6px; align-items:center;">
                <button id="orderFirstPage" class="page-btn" type="button">&laquo; Đầu</button>
                <button id="orderPrevPage" class="page-btn" type="button">&lsaquo; Trước</button>
                <div id="orderPageNumbers" style="display:flex; gap:6px;"></div>
                <button id="orderNextPage" class="page-btn" type="button">Tiếp &rsaquo;</button>
                <button id="orderLastPage" class="page-btn" type="button">Cuối &raquo;</button>
            </div>
        </div>
    </div>
</div>

<script>// Client-side sorting + pagination for Orders (dựa trên Admin_Users/Index)
    document.addEventListener('DOMContentLoaded', function () {
        const tbody = document.getElementById('ordersTbody');
        let items = Array.from(tbody.querySelectorAll('.data-row')).map(row => {
            const tds = row.querySelectorAll('td');
            const getText = idx => (tds[idx] ? tds[idx].innerText.trim() : '').toLowerCase();
            // total: cố gắng bỏ tất cả ký tự không phải số để so sánh số
            const totalRaw = (tds[3] ? tds[3].innerText : '').replace(/[^\d\-]/g, '') || '';
            const dateRaw = (tds[2] ? tds[2].innerText.trim() : '');
            return {
                row: row,
                shipment_address: getText(0),
                customer: getText(1),
                order_date: dateRaw, // giữ dạng dd/MM/yyyy hoặc "—"
                total_amount: totalRaw,
                status: getText(4),
                payment_method: getText(5)
            };
        });

        let rowsElems = items.map(i => i.row);
        const headers = Array.from(document.querySelectorAll('.orders-table thead th.sortable'));
        let currentSort = { key: null, dir: null };

        function setSortIndicator(header, dir) {
            headers.forEach(h => {
                const ind = h.querySelector('.sort-indicator');
                if (h === header) ind.textContent = dir === 'asc' ? '▲' : dir === 'desc' ? '▼' : '';
                else ind.textContent = '';
            });
        }

        function parseDateDMY(text) {
            // trả về chuỗi YYYYMMDD để so sánh; nếu không parse được trả về empty string
            if (!text) return '';
            text = text.trim();
            if (text === '—' || text === '-') return '';
            const parts = text.split('/');
            if (parts.length !== 3) return text;
            const d = parts[0].padStart(2, '0');
            const m = parts[1].padStart(2, '0');
            const y = parts[2].length === 2 ? ('20' + parts[2]) : parts[2];
            return y + m + d;
        }

        function compareValues(a, b, key, dir) {
            const va = a[key] || '', vb = b[key] || '';
            // số tiền so sánh theo số
            if (key === 'total_amount') {
                const na = parseInt(va || '0', 10) || 0;
                const nb = parseInt(vb || '0', 10) || 0;
                if (na < nb) return dir === 'asc' ? -1 : 1;
                if (na > nb) return dir === 'asc' ? 1 : -1;
                return 0;
            }
            // ngày: dd/MM/yyyy -> YYYYMMDD so sánh chuỗi
            if (key === 'order_date') {
                const da = parseDateDMY(va);
                const db = parseDateDMY(vb);
                if (da < db) return dir === 'asc' ? -1 : 1;
                if (da > db) return dir === 'asc' ? 1 : -1;
                return 0;
            }
            // default: so sánh chuỗi
            if (va < vb) return dir === 'asc' ? -1 : 1;
            if (va > vb) return dir === 'asc' ? 1 : -1;
            return 0;
        }

        headers.forEach(h => {
            h.addEventListener('click', function () {
                const key = this.dataset.sort;
                let dir = 'asc';
                if (currentSort.key === key) dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                currentSort = { key, dir };

                items.sort((a, b) => compareValues(a, b, key, dir));
                items.forEach(it => tbody.appendChild(it.row));
                rowsElems = items.map(i => i.row);

                setSortIndicator(this, dir);

                currentPage = 1;
                showPage(currentPage);
            });
        });

        // pagination (uses rowsElems)
        const pageSizeSelect = document.getElementById('orderPageSize');
        const pageNumbersContainer = document.getElementById('orderPageNumbers');
        const firstBtn = document.getElementById('orderFirstPage');
        const prevBtn = document.getElementById('orderPrevPage');
        const nextBtn = document.getElementById('orderNextPage');
        const lastBtn = document.getElementById('orderLastPage');

        let pageSize = parseInt(pageSizeSelect.value, 10) || 10;
        let currentPage = 1;

        function calculateTotalPages() {
            return pageSize > 0 ? Math.max(1, Math.ceil(rowsElems.length / pageSize)) : 1;
        }

        function renderPageNumbers() {
            pageNumbersContainer.innerHTML = '';
            const totalPages = calculateTotalPages();
            const maxButtons = 7;
            let start = Math.max(1, currentPage - Math.floor(maxButtons / 2));
            let end = Math.min(totalPages, start + maxButtons - 1);
            if (end - start + 1 < maxButtons) { start = Math.max(1, end - maxButtons + 1); }
            for (let i = start; i <= end; i++) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                btn.textContent = i;
                btn.dataset.page = i;
                btn.addEventListener('click', function () {
                    currentPage = parseInt(this.dataset.page, 10);
                    showPage(currentPage);
                });
                pageNumbersContainer.appendChild(btn);
            }
        }

        function showPage(page) {
            const totalPages = calculateTotalPages();
            if (page < 1) page = 1;
            if (page > totalPages) page = totalPages;
            currentPage = page;
            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = startIndex + pageSize;
            rowsElems.forEach((r, idx) => {
                r.style.display = (idx >= startIndex && idx < endIndex) ? '' : 'none';
            });
            renderPageNumbers();
            prevBtn.disabled = currentPage === 1;
            firstBtn.disabled = currentPage === 1;
            nextBtn.disabled = currentPage === totalPages;
            lastBtn.disabled = currentPage === totalPages;
        }

        pageSizeSelect.addEventListener('change', function () {
            pageSize = parseInt(this.value, 10) || 10;
            currentPage = 1;
            showPage(currentPage);
        });
        firstBtn.addEventListener('click', function () { showPage(1); });
        prevBtn.addEventListener('click', function () { showPage(currentPage - 1); });
        nextBtn.addEventListener('click', function () { showPage(currentPage + 1); });
        lastBtn.addEventListener('click', function () { showPage(calculateTotalPages()); });

        // initial render
        showPage(1);
    });</script>